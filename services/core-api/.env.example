# ============================================================================
# Miori Core — root environment template
# Copy to .env and adjust. Each app/service may also have its own .env.example.
#
# NOTE: the core-api Settings class (services/core-api/app/core/config.py) has
# NO env prefix, so it reads these BARE names (case-insensitive). The frontends
# read the VITE_* names below via import.meta.env.
# ============================================================================

# ---- Core API (services/core-api) ----
APP_NAME=Miori Core
APP_VERSION=1.1.0
DEBUG=true
HOST=127.0.0.1
PORT=8000
DATABASE_URL=sqlite:///./miori.db

# ---- Feature Flags ----
# Lite mode keeps heavy/optional deps (vector DB, embedding models) lazy/off.
LITE_MODE=true

# Remote dashboard access. Only expose on LAN when explicitly enabled.
REMOTE_ENABLED=true

# If set, enforces Bearer token auth in the REST API. If empty, open (returns DEV user).
MIORI_API_TOKEN=

# When true, MemoryService uses embedding + vector search.
SEMANTIC_MEMORY_ENABLED=false

# When true, allows the computer-use tool to be armed and used. Off by default for safety.
COMPUTER_USE_ENABLED=false
# When true, allows computer-use tool to execute shell commands.
COMPUTER_USE_SHELL_ENABLED=false

# When true, the APScheduler background task system is spun up.
SCHEDULER_ENABLED=true

# ---- Paths & Settings ----
PROMPTS_DIR=../../packages/prompts
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_BYTES=26214400
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Comma-separated allowed CORS origins for the desktop + remote frontends.
CORS_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5173,http://127.0.0.1:5173

# ---- Frontends ----
# Desktop app (apps/desktop/src/lib/api.ts + ws.ts) reads these. 
VITE_MIORI_API=http://localhost:8000/api
VITE_MIORI_WS=ws://localhost:8000/ws/chat

# ---- Model Providers ----
DEFAULT_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (GEMINI_API_KEY preferred; GOOGLE_API_KEY accepted)
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# SambaNova
SAMBANOVA_API_KEY=
SAMBANOVA_MODEL=Meta-Llama-3.1-8B-Instruct

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Hugging Face
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Cohere
COHERE_API_KEY=
COHERE_MODEL=command-r

# Cloudflare Workers AI
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct
